# --- Application ---
ENV=production
APP_BASE_URL=https://lasandra-disputable-nonconvertibly.ngrok-free.dev
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://lasandra-disputable-nonconvertibly.ngrok-free.dev

# --- Database (PostgreSQL) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Local connection string (for running on host)
DATABASE_URL=

# Docker connection string (for running inside container)
DOCKER_DATABASE_URL=

# --- Security ---
SECRET_KEY=

# --- AI Configuration ---
LLM_MODEL=
OLLAMA_BASE_URL=

# --- Email Configuration (Gmail SMTP) ---
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Ngrok Configuration ---
# Sign up at ngrok.com to get your authtoken
NGROK_AUTHTOKEN=

# --- Firebase Push Notifications ---
# Can be a path to your adminsdk JSON file locally, or a raw stringified JSON on Render
FIREBASE_SERVICE_ACCOUNT_JSON=firebase-adminsdk.json
